{
  "extends": "./tsconfig.json",
  "include": ["server/**/*", "shared/**/*"],
  "exclude": [
    "node_modules", 
    "dist", 
    "client",
    "server/auth-enhanced.ts",
    "server/routes/affiliates.ts",
    "server/routes/products.ts",
    "server/routes/products-sqlite.ts",
    "server/middleware/security.ts",
    "server/middleware/tracking.ts"
  ],
  "compilerOptions": {
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": ".",
    "module": "commonjs",
    "target": "ES2020",
    "lib": ["ES2020"],
    "moduleResolution": "node",
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "sourceMap": true,
    "declaration": false,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "types": ["node"],
    "paths": {
      "@shared/*": ["./shared/*"]
    }
  }
}